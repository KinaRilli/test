<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>С Днём Рождения!</title>
<link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400;600;700&family=Montserrat:wght@300;400;500;600&family=Caveat:wght@400;600&display=swap" rel="stylesheet">
<style>
  :root {
    --magenta: #f035e0;
    --magenta-hover: #d020c0;
    --text-dark: #333;
    --text-light: #666;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { width: 100%; height: 100%; overflow: hidden; font-family: 'Montserrat', sans-serif; }

  /* ── ОБЩИЕ СТИЛИ ЭКРАНОВ ── */
  .screen {
    position: fixed; inset: 0; display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none; transition: opacity 0.6s ease; overflow: hidden;
  }
  .screen.active { opacity: 1; pointer-events: all; }

  /* ── ФОНЫ ── */
  .bg-light {
    position: absolute; inset: 0; z-index: -5;
    background: url('https://gcdnb.pbrd.co/images/nb4Rw683nyTY.png?o=1') center/cover no-repeat;
  }

  .bg-room {
    position: absolute; inset: 0; z-index: -2;
    /* Тот самый фон комнаты с белыми шарами */
    background: url('https://gcdnb.pbrd.co/images/EKRHDiaBaFiN.png?o=1') center/cover no-repeat;
  }
  /* Затемнение для комнаты, чтобы текст лучше читался */
  .bg-room::after {
    content: ''; position: absolute; inset: 0; background: rgba(255,255,255,0.3);
  }

  /* ── ЭКРАНЫ 1 и 2: КОНВЕРТЫ ── */
  .landing-layout {
    display: flex; width: 100%; max-width: 900px; justify-content: space-around; align-items: center; padding: 20px;
  }
  .landing-text { text-align: center; color: #8e6d51; }
  .hb-happy { font-weight: 500; font-size: clamp(30px, 4vw, 42px); display: block; margin-bottom: -10px; }
  .hb-birthday { font-family: 'Dancing Script', cursive; font-size: clamp(60px, 8vw, 110px); display: block; line-height: 1; color: #a47b59;}
  .hb-sub { font-weight: 300; font-size: 18px; letter-spacing: 2px; }

  .env-float { cursor: pointer; transition: transform 0.3s; animation: float 3s ease-in-out infinite; }
  .env-float:hover { transform: scale(1.05); }
  @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-15px); } }

  /* ── ЭКРАН 3: ПИСЬМО (КАРТОЧКА) ── */
  .bday-card {
    width: clamp(280px, 40vw, 400px); background: #fff; border-radius: 16px; overflow: hidden;
    box-shadow: 0 15px 40px rgba(160,100,130,0.2); border: 1px solid rgba(220,180,200,0.3);
    text-align: center; padding: 30px 20px;
    background-image: repeating-linear-gradient(transparent, transparent 26px, rgba(180,160,200,0.1) 26px, rgba(180,160,200,0.1) 27px);
  }
  .bcard-title { font-family: 'Dancing Script', cursive; font-size: 32px; color: #9b7dc7; margin-bottom: 20px; font-weight: 700; }
  .bcard-text { font-family: 'Caveat', cursive; font-size: 22px; color: #5a4060; line-height: 1.6; margin-bottom: 20px; }
  
  /* ── МОДАЛЬНЫЕ ОКНА (Экраны 4, 5, 6) ── */
  .modal {
    background: rgba(255, 255, 255, 0.98); border-radius: 24px; box-shadow: 0 20px 50px rgba(0,0,0,0.15);
    padding: 50px 40px; text-align: center; max-width: 500px; width: 90%;
    animation: slideUp 0.5s ease-out; position: relative; z-index: 10;
  }
  @keyframes slideUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }

  .modal-title { font-size: 32px; font-weight: 400; color: var(--magenta); margin-bottom: 15px; }
  .modal-text { font-size: 16px; color: var(--text-light); line-height: 1.6; margin-bottom: 30px; font-weight: 400; }
  
  .btn {
    background: var(--magenta); color: #fff; font-family: 'Montserrat', sans-serif; font-size: 16px; font-weight: 600;
    border: none; border-radius: 50px; padding: 15px 40px; cursor: pointer; transition: 0.2s; box-shadow: 0 8px 20px rgba(240, 53, 224, 0.4);
  }
  .btn:hover { background: var(--magenta-hover); transform: translateY(-2px); box-shadow: 0 10px 25px rgba(240, 53, 224, 0.5); }

  /* ── ИГРА (Экран 5) ── */
  .hearts-container { display: flex; justify-content: center; gap: 10px; margin-bottom: 30px; }
  .heart { width: 35px; height: 35px; fill: red; transition: 0.3s; }
  .heart.lost { fill: #ccc; transform: scale(0.8); opacity: 0.5; }
  .game-hint { font-family: 'Caveat', cursive; font-size: 28px; color: var(--text-dark); margin-bottom: 40px; }
  
  .boxes-container { display: flex; justify-content: center; gap: 30px; }
  .box-btn { 
    background: none; border: none; cursor: pointer; transition: transform 0.2s;
    animation: boxFloat 2.5s ease-in-out infinite;
  }
  .box-btn:hover { transform: scale(1.1) translateY(-5px); }
  @keyframes boxFloat { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }

  /* ── ПОБЕДА (Экран 6) ── */
  .win-modal {
    display: flex; max-width: 850px; width: 95%; background: #fff; border-radius: 24px;
    overflow: hidden; box-shadow: 0 20px 50px rgba(0,0,0,0.2); animation: slideUp 0.5s ease-out;
  }
  .win-note-side {
    flex: 1.2; padding: 40px; background: #fffaf0; position: relative; border-right: 1px solid #eee;
    background-image: repeating-linear-gradient(transparent, transparent 29px, #e8d0d8 30px);
    background-position: 0 10px;
  }
  .note-text { font-family: 'Caveat', cursive; font-size: 22px; line-height: 1.5; color: #4a3b42; position: relative; z-index: 2; }
  .win-prize-side {
    flex: 1; padding: 40px; display: flex; flex-direction: column; align-items: center; justify-content: center;
  }
  .win-prize-title { font-family: 'Caveat', cursive; font-size: 26px; color: #333; margin-bottom: 20px; text-align: center; }
  
  .prize-image { 
    max-width: 150px; 
    filter: drop-shadow(0 10px 20px rgba(0,0,0,0.2));
    animation: zoomIn 0.8s cubic-bezier(0.17, 0.67, 0.83, 0.67);
  }
  @keyframes zoomIn { from { transform: scale(0); } to { transform: scale(1); } }

  #confetti { position: fixed; inset: 0; pointer-events: none; z-index: 9999; }

  @media (max-width: 768px) {
    .landing-layout { flex-direction: column; gap: 40px; }
    .win-modal { flex-direction: column; }
    .win-note-side { border-right: none; border-bottom: 1px solid #eee; }
  }
</style>
</head>
<body>

<canvas id="confetti"></canvas>

<div class="screen active" id="s1">
  <div style="position: absolute; inset: 0; z-index: -2; background: url('ССЫЛКА_НА_ТВОЙ_ФОН') center/cover no-repeat;"></div>
  
  <div class="landing-layout">
    <div class="landing-text">
      <span class="hb-happy">Happy</span>
      <span class="hb-birthday">Birthday</span>
      <span class="hb-sub">Best Wishes!</span>
    </div>
    <div class="env-float" onclick="goTo(2)">
      <img src="ССЫЛКА_НА_ТВОЙ_КОНВЕРТ" style="width: clamp(250px, 30vw, 350px); height: auto;">
      <div style="text-align: center; color: #a47b59; font-size: 14px; margin-top: 15px;">✨ нажми, чтобы открыть ✨</div>
    </div>
  </div>
</div>

<div class="screen" id="s2">
  <div class="bg-light"></div>
  <div class="landing-layout">
    <div class="landing-text">
      <span class="hb-happy">Happy</span>
      <span class="hb-birthday">Birthday</span>
      <span class="hb-sub">Best Wishes!</span>
    </div>
    <div class="env-float">
      <svg width="300" viewBox="0 0 320 288" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="54" y="8" width="212" height="158" rx="10" fill="white" stroke="#e8d0e0" stroke-width="0.8"/>
        <text x="160" y="45" text-anchor="middle" font-family="Dancing Script,cursive" font-size="22" fill="#9b7dc7" font-weight="700">С Днём Рождения!</text>
        <text x="160" y="85" text-anchor="middle" font-family="Caveat,cursive" font-size="14" fill="#7a5060">Желаю тебе счастья,</text>
        <text x="160" y="105" text-anchor="middle" font-family="Caveat,cursive" font-size="14" fill="#7a5060">вдохновения и любви!</text>
        <rect x="8" y="104" width="304" height="174" rx="13" fill="#f8f2fe" stroke="#d0b8e8" stroke-width="1"/>
        <polygon points="8,104 160,6 312,104" fill="#dcc0e8" stroke="#c0a8d8" stroke-width="0.9"/>
        <line x1="8" y1="278" x2="160" y2="188" stroke="#d0b8e8" stroke-width="0.7"/>
        <line x1="312" y1="278" x2="160" y2="188" stroke="#d0b8e8" stroke-width="0.7"/>
      </svg>
    </div>
  </div>
</div>

<div class="screen" id="s3">
  <div class="bg-light"></div>
  <div class="bday-card">
    <div class="bcard-title">С Днём Рождения!</div>
    <div class="bcard-text">
      Желаю тебе счастья, вдохновения, любви и исполнения всех заветных желаний!<br><br>
      Пусть каждый твой день приносит радость и улыбки!
    </div>
    <div style="font-size: 14px; color: #8060a0; margin-bottom: 15px;">Нажми сюда что бы получить свой подарок.</div>
    <button class="btn" onclick="goTo(4)" style="padding: 12px 30px;">Сюда</button>
  </div>
</div>

<div class="screen" id="s4">
  <div class="bg-room"></div>
  <div class="modal">
    <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="var(--magenta)" stroke-width="1.5" style="margin: 0 auto 15px; display: block;">
      <rect x="3" y="8" width="18" height="13" rx="1"></rect><path d="M12 8V21"></path><path d="M19 8c0-3-3.5-5-7-2-3.5-3-7-1-7 2s3 4 7 4 7-1 7-4z"></path>
    </svg>
    <h2 class="modal-title">Мини-игра</h2>
    <p class="modal-text">
      Выиграй в мини игре что бы получить подарок.<br>
      У тебя есть только 3 жизни что бы угадать<br>в каком из коробок твой подарок.
    </p>
    <button class="btn" onclick="startGame()">Начать игру</button>
  </div>
</div>

<div class="screen" id="s5">
  <div class="bg-room"></div>
  <div class="modal">
    <div class="hearts-container">
      <svg class="heart" id="h1" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
      <svg class="heart" id="h2" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
      <svg class="heart" id="h3" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
    </div>
    
    <div class="game-hint">Желаю удачи угадать в каком из коробок твой подарок</div>
    
    <div class="boxes-container">
      <button class="box-btn" onclick="pickBox(this)">
        <svg width="70" height="70" viewBox="0 0 24 24" fill="#00d2ff"><rect x="3" y="8" width="18" height="14" rx="2"></rect><path d="M12 8V22M19 8c0-3-3.5-5-7-2-3.5-3-7-1-7 2s3 4 7 4 7-1 7-4z" stroke="white" stroke-width="1.5"/></svg>
      </button>
      <button class="box-btn" onclick="pickBox(this)">
        <svg width="70" height="70" viewBox="0 0 24 24" fill="#4a69bd"><rect x="3" y="8" width="18" height="14" rx="2"></rect><path d="M12 8V22M19 8c0-3-3.5-5-7-2-3.5-3-7-1-7 2s3 4 7 4 7-1 7-4z" stroke="white" stroke-width="1.5"/></svg>
      </button>
      <button class="box-btn" onclick="pickBox(this)">
        <svg width="70" height="70" viewBox="0 0 24 24" fill="#a55eea"><rect x="3" y="8" width="18" height="14" rx="2"></rect><path d="M12 8V22M19 8c0-3-3.5-5-7-2-3.5-3-7-1-7 2s3 4 7 4 7-1 7-4z" stroke="white" stroke-width="1.5"/></svg>
      </button>
    </div>
  </div>
</div>

<div class="screen" id="s4"></div> <div class="screen" id="s6">
  <div class="bg-room"></div>
  <div class="win-modal">
    <div class="win-note-side">
      <div class="note-text">
        <p>Поздравляю! ты нашел свой подарок</p>
        <p>вообще в этой мини-игре невозможно было бы проиграть так как он устроен что бы когда оставалась последняя жизнь во всех коробках был твой подарок и неважно что бы ты выбрала так как ты бы выиграла в любом случае.</p>
      </div>
      <div style="font-size: 40px; position: absolute; bottom: 20px; left: 20px;">🎂🎉</div>
    </div>

    <div class="win-prize-side">
      <div class="win-prize-title">Вот твой подарок который ты заслужила</div>
      <img src="https://gcdnb.pbrd.co/images/MuK71pVhfAW4.png?o=1" class="prize-image" alt="Микрофон HyperX">
    </div>
  </div>
</div>

<script>
  function goTo(screenId) {
    document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
    document.getElementById('s' + screenId).classList.add('active');
    
    // Автоматический переход от открытого конверта к самому письму через 1.5 секунды
    if (screenId === 2) {
      setTimeout(() => goTo(3), 1500);
    }
  }

  let lives = 3;

  function startGame() {
    lives = 3;
    document.querySelectorAll('.heart').forEach(h => h.classList.remove('lost'));
    document.querySelectorAll('.box-btn').forEach(b => {
      b.style.opacity = '1';
      b.style.pointerEvents = 'all';
      b.style.transform = 'scale(1)';
    });
    goTo(5); // Переход на экран игры
  }

  function pickBox(btnElement) {
    if (lives > 1) {
      // Отнимаем жизнь
      document.getElementById('h' + lives).classList.add('lost');
      lives--;
      btnElement.style.opacity = '0.3';
      btnElement.style.pointerEvents = 'none';
      btnElement.style.transform = 'scale(0.9)';
    } else {
      // Последний клик = победа
      goTo(6);
      fireConfetti();
    }
  }

  // Конфетти для победы
  function fireConfetti() {
    const canvas = document.getElementById('confetti');
    const ctx = canvas.getContext('2d');
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
    
    const pieces = [];
    const colors = ['#f035e0', '#00d2ff', '#d4af37', '#a55eea', '#ff4757'];
    
    for (let i = 0; i < 150; i++) {
      pieces.push({
        x: canvas.width / 2, y: canvas.height / 2 + 50,
        vx: (Math.random() - 0.5) * 25, vy: (Math.random() - 1) * 25,
        size: Math.random() * 10 + 5, color: colors[Math.floor(Math.random() * colors.length)],
        rotation: Math.random() * 360, rotationSpeed: (Math.random() - 0.5) * 10
      });
    }

    function animate() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      let active = false;
      pieces.forEach(p => {
        p.x += p.vx; p.y += p.vy; p.vy += 0.6; p.rotation += p.rotationSpeed;
        if (p.y < canvas.height + 50) active = true;
        ctx.save(); ctx.translate(p.x, p.y); ctx.rotate(p.rotation * Math.PI / 180);
        ctx.fillStyle = p.color; ctx.fillRect(-p.size/2, -p.size/2, p.size, p.size); ctx.restore();
      });
      if (active) requestAnimationFrame(animate);
    }
    animate();
  }
</script>

</body>
</html>
