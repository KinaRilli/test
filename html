<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>С Днём Рождения!</title>
<link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;600&family=Montserrat:wght@300;400;500;600&family=Great+Vibes&display=swap" rel="stylesheet">
<style>
  :root {
    --magenta: #f035e0;
    --magenta-hover: #d020c0;
    --text-dark: #333;
    --text-light: #666;
    --bg-overlay: rgba(0, 0, 0, 0.4);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { width: 100%; height: 100%; overflow: hidden; font-family: 'Montserrat', sans-serif; }

  /* ── ОБЩИЕ СТИЛИ ЭКРАНОВ ── */
  .screen {
    position: fixed; inset: 0; display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none; transition: opacity 0.6s ease; overflow: hidden;
  }
  .screen.active { opacity: 1; pointer-events: all; }

  /* ── ФОН 1: СВЕТЛЫЙ (Экраны 1-3) ── */
  .bg-light {
    position: absolute; inset: 0; z-index: -2;
    /* Сюда лучше вставить картинку с шариками из макета (файлы 3, 4, 5.png) */
    background: linear-gradient(135deg, #fdf5f4 0%, #f7e6e5 100%); 
    background-size: cover; background-position: center;
  }

  /* ── ФОН 2: КОМНАТА С ШАРАМИ (Экраны 4-7) ── */
  .bg-room {
    position: absolute; inset: 0; z-index: -2;
    /* ЗАМЕНИТЕ URL НА ВАШУ КАРТИНКУ ФОНА КОМНАТЫ */
    background: url('party-room-bg.jpg') center/cover no-repeat;
    background-color: #d1c9c4; /* Заглушка, если картинки нет */
  }
  
  /* Декоративные коробки с подарками внизу экрана */
  .bottom-gifts-left, .bottom-gifts-right {
    position: absolute; bottom: -10px; z-index: -1; pointer-events: none;
  }
  .bottom-gifts-left { left: 0; width: 350px; }
  .bottom-gifts-right { right: 0; width: 300px; }

  /* ── ЭКРАН 1: ЛЕНДИНГ ── */
  .landing-layout {
    display: flex; width: 100%; max-width: 1000px; justify-content: space-between; align-items: center; padding: 0 40px;
  }
  .landing-text { text-align: center; color: #8e6d51; }
  .hb-happy { font-family: 'Montserrat', sans-serif; font-weight: 500; font-size: 42px; display: block; margin-bottom: -15px; }
  .hb-birthday { font-family: 'Great Vibes', cursive; font-size: 110px; display: block; }
  .hb-sub { font-family: 'Montserrat', sans-serif; font-size: 18px; font-weight: 300; letter-spacing: 2px; }

  /* Конверт-заглушка */
  .envelope-wrapper { cursor: pointer; transition: transform 0.3s; animation: float 3s ease-in-out infinite; }
  .envelope-wrapper:hover { transform: scale(1.05); }
  @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-15px); } }

  /* ── МОДАЛЬНЫЕ ОКНА (Мини-игра) ── */
  .modal {
    background: #ffffff; border-radius: 20px; box-shadow: 0 20px 50px rgba(0,0,0,0.15);
    padding: 50px 40px; text-align: center; max-width: 500px; width: 90%;
    animation: slideUp 0.5s ease-out; position: relative; z-index: 10;
  }
  @keyframes slideUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }

  .modal-icon { margin: 0 auto 20px; width: 60px; height: 60px; }
  .modal-title { font-size: 32px; font-weight: 400; color: var(--magenta); margin-bottom: 15px; }
  .modal-text { font-size: 15px; color: var(--text-light); line-height: 1.6; margin-bottom: 30px; font-weight: 300; }
  
  .btn {
    background: var(--magenta); color: #fff; font-family: 'Montserrat', sans-serif; font-size: 16px; font-weight: 500;
    border: none; border-radius: 50px; padding: 15px 40px; cursor: pointer; transition: 0.2s; box-shadow: 0 8px 20px rgba(240, 53, 224, 0.4);
  }
  .btn:hover { background: var(--magenta-hover); transform: translateY(-2px); box-shadow: 0 10px 25px rgba(240, 53, 224, 0.5); }
  .btn:active { transform: scale(0.96); }

  /* ── ИГРА: СЕРДЦА И КОРОБКИ ── */
  .hearts-container { display: flex; justify-content: center; gap: 10px; margin-bottom: 30px; }
  .heart { width: 30px; height: 30px; fill: red; transition: 0.3s; }
  .heart.lost { fill: #ccc; transform: scale(0.8); opacity: 0.5; }
  
  .game-hint { font-family: 'Caveat', cursive; font-size: 26px; color: var(--text-dark); margin-bottom: 40px; }
  
  .boxes-container { display: flex; justify-content: center; gap: 30px; }
  .box-btn { 
    background: none; border: none; cursor: pointer; transition: transform 0.2s;
    animation: boxFloat 2.5s ease-in-out infinite;
  }
  .box-btn:nth-child(2) { animation-delay: 0.2s; }
  .box-btn:nth-child(3) { animation-delay: 0.4s; }
  .box-btn:hover { transform: scale(1.1) translateY(-5px); }
  @keyframes boxFloat { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }

  /* ── ЭКРАН ПОБЕДЫ (Письмо + Подарок) ── */
  .win-modal {
    display: flex; max-width: 800px; width: 95%; background: #fff; border-radius: 20px;
    overflow: hidden; box-shadow: 0 20px 50px rgba(0,0,0,0.2); animation: slideUp 0.5s ease-out;
  }
  .win-note-side {
    flex: 1; padding: 40px; background: #fffaf0; position: relative; border-right: 1px solid #eee;
    /* Имитация тетрадного листа/блокнота */
    background-image: repeating-linear-gradient(transparent, transparent 29px, #e8d0d8 30px);
    background-position: 0 10px;
  }
  /* Декоративная рамка конфетти для письма */
  .win-note-side::before {
    content: ''; position: absolute; inset: 10px; border: 2px dashed #fcdced; pointer-events: none; border-radius: 10px;
  }
  .note-text {
    font-family: 'Caveat', cursive; font-size: 20px; line-height: 30px; color: #4a3b42; position: relative; z-index: 2;
  }
  .win-prize-side {
    flex: 1; padding: 40px; display: flex; flex-direction: column; align-items: center; justify-content: center;
  }
  .win-prize-title { font-family: 'Caveat', cursive; font-size: 26px; color: #333; margin-bottom: 20px; text-align: center; }
  .prize-image { max-width: 150px; margin-bottom: 20px; }

  /* Конфетти Canvas */
  #confetti { position: fixed; inset: 0; pointer-events: none; z-index: 9999; }

  @media (max-width: 768px) {
    .landing-layout { flex-direction: column; text-align: center; justify-content: center; gap: 40px; }
    .win-modal { flex-direction: column; }
    .win-note-side { border-right: none; border-bottom: 1px solid #eee; padding: 30px 20px; }
    .boxes-container { gap: 15px; }
    .hb-birthday { font-size: 80px; }
  }
</style>
</head>
<body>

<canvas id="confetti"></canvas>

<div class="screen active" id="s1">
  <div class="bg-light"></div>
  <div class="landing-layout">
    <div class="landing-text">
      <span class="hb-happy">Happy</span>
      <span class="hb-birthday">Birthday</span>
      <span class="hb-sub">Best Wishes!</span>
    </div>
    
    <div class="envelope-wrapper" onclick="goTo('s2')">
      <svg width="250" height="180" viewBox="0 0 250 180" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="250" height="180" rx="10" fill="#Fdf5f0" stroke="#E5C5C5" stroke-width="2"/>
        <path d="M0 10C0 4.47715 4.47715 0 10 0H240C245.523 0 250 4.47715 250 10V90L125 150L0 90V10Z" fill="#F4E0E0"/>
        <path d="M0 180L125 90L250 180" stroke="#E5C5C5" stroke-width="2"/>
        <circle cx="125" cy="90" r="15" fill="#D4AF37"/>
        <text x="125" y="140" font-family="Montserrat" font-size="12" fill="#8e6d51" text-anchor="middle">Нажми чтобы открыть</text>
      </svg>
    </div>
  </div>
</div>

<div class="screen" id="s2">
  <div class="bg-room"></div>
  
  <img src="https://via.placeholder.com/350x200?text=Gifts+Left" alt="" class="bottom-gifts-left" style="opacity: 0;"> 
  <img src="https://via.placeholder.com/300x200?text=Gifts+Right" alt="" class="bottom-gifts-right" style="opacity: 0;">

  <div class="modal">
    <svg class="modal-icon" viewBox="0 0 24 24" fill="none" stroke="var(--magenta)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="8" width="18" height="13" rx="1"></rect>
      <path d="M12 8V21"></path>
      <path d="M19 8c0-3-3.5-5-7-2-3.5-3-7-1-7 2s3 4 7 4 7-1 7-4z"></path>
    </svg>
    <h2 class="modal-title">Мини-игра</h2>
    <p class="modal-text">
      Выиграй в мини игре что бы получить подарок.<br>
      У тебя есть только 3 жизни что бы угадать<br>в каком из коробок твой подарок.
    </p>
    <button class="btn" onclick="startGame()">Начать игру</button>
  </div>
</div>

<div class="screen" id="s3">
  <div class="bg-room"></div>
  <div class="modal" style="padding-bottom: 60px;">
    <div class="hearts-container">
      <svg class="heart" id="h1" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
      <svg class="heart" id="h2" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
      <svg class="heart" id="h3" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
    </div>
    
    <div class="game-hint">Желаю удачи угадать в каком из коробок твой подарок</div>
    
    <div class="boxes-container">
      <button class="box-btn" onclick="pickBox(this)">
        <svg width="60" height="60" viewBox="0 0 24 24" fill="#00d2ff" stroke="#00a8cc" stroke-width="1.5">
          <rect x="3" y="8" width="18" height="14" rx="1"></rect><path d="M12 8V22"></path><path d="M19 8c0-3-3.5-5-7-2-3.5-3-7-1-7 2s3 4 7 4 7-1 7-4z"></path>
        </svg>
      </button>
      <button class="box-btn" onclick="pickBox(this)">
        <svg width="60" height="60" viewBox="0 0 24 24" fill="#4a69bd" stroke="#1e3799" stroke-width="1.5">
          <rect x="3" y="8" width="18" height="14" rx="1"></rect><path d="M12 8V22"></path><path d="M19 8c0-3-3.5-5-7-2-3.5-3-7-1-7 2s3 4 7 4 7-1 7-4z"></path>
        </svg>
      </button>
      <button class="box-btn" onclick="pickBox(this)">
        <svg width="60" height="60" viewBox="0 0 24 24" fill="#a55eea" stroke="#8854d0" stroke-width="1.5">
          <rect x="3" y="8" width="18" height="14" rx="1"></rect><path d="M12 8V22"></path><path d="M19 8c0-3-3.5-5-7-2-3.5-3-7-1-7 2s3 4 7 4 7-1 7-4z"></path>
        </svg>
      </button>
    </div>
  </div>
</div>

<div class="screen" id="s4">
  <div class="bg-room"></div>
  <div class="win-modal">
    
    <div class="win-note-side">
      <div class="note-text">
        <p style="margin-bottom: 10px;">Поздравляю! ты нашел свой подарок</p>
        <p>вообще в этой мини-игре невозможно было бы проиграть так как он устроен что бы когда оставалась последняя жизнь во всех коробках был твой подарок и неважно что бы ты выбрала так как ты бы выиграла в любом случае.</p>
      </div>
      <div style="font-size: 40px; position: absolute; bottom: 20px; left: 20px;">🎂🎉</div>
    </div>

    <div class="win-prize-side">
      <div class="win-prize-title">Вот твой подарок который ты заслужила</div>
      <svg width="100" height="150" viewBox="0 0 24 36" fill="none" stroke="#222" stroke-width="2" class="prize-image">
        <rect x="6" y="2" width="12" height="20" rx="6" fill="#e02b2b" stroke="#333"/>
        <path d="M4 14v4a8 8 0 0016 0v-4M12 26v8M8 34h8"/>
      </svg>
    </div>

  </div>
</div>

<script>
  // Навигация между экранами
  function goTo(screenId) {
    document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
    document.getElementById(screenId).classList.add('active');
  }

  // Логика игры
  let lives = 3;

  function startGame() {
    lives = 3;
    // Сбрасываем сердца
    document.querySelectorAll('.heart').forEach(h => h.classList.remove('lost'));
    // Сбрасываем коробки
    document.querySelectorAll('.box-btn').forEach(b => {
      b.style.opacity = '1';
      b.style.pointerEvents = 'all';
      b.style.transform = 'scale(1)';
    });
    goTo('s3');
  }

  function pickBox(btnElement) {
    if (lives > 1) {
      // Первые две попытки: отнимаем жизнь и "убираем" коробку
      document.getElementById('h' + lives).classList.add('lost');
      lives--;
      
      btnElement.style.opacity = '0.3';
      btnElement.style.pointerEvents = 'none';
      btnElement.style.transform = 'scale(0.9)';
    } else {
      // Последняя жизнь: Всегда победа!
      goTo('s4');
      fireConfetti();
    }
  }

  // Простой генератор конфетти для праздничного эффекта
  function fireConfetti() {
    const canvas = document.getElementById('confetti');
    const ctx = canvas.getContext('2d');
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
    
    const pieces = [];
    const colors = ['#f035e0', '#00d2ff', '#d4af37', '#a55eea', '#ff4757'];
    
    for (let i = 0; i < 150; i++) {
      pieces.push({
        x: canvas.width / 2,
        y: canvas.height / 2 + 100,
        vx: (Math.random() - 0.5) * 25,
        vy: (Math.random() - 1) * 25,
        size: Math.random() * 10 + 5,
        color: colors[Math.floor(Math.random() * colors.length)],
        rotation: Math.random() * 360,
        rotationSpeed: (Math.random() - 0.5) * 10
      });
    }

    function animate() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      let active = false;
      
      pieces.forEach(p => {
        p.x += p.vx;
        p.y += p.vy;
        p.vy += 0.5; // гравитация
        p.rotation += p.rotationSpeed;
        
        if (p.y < canvas.height) active = true;

        ctx.save();
        ctx.translate(p.x, p.y);
        ctx.rotate(p.rotation * Math.PI / 180);
        ctx.fillStyle = p.color;
        ctx.fillRect(-p.size/2, -p.size/2, p.size, p.size);
        ctx.restore();
      });

      if (active) requestAnimationFrame(animate);
      else ctx.clearRect(0, 0, canvas.width, canvas.height);
    }
    animate();
  }
</script>

</body>
</html>
