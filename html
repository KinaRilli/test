<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Твой Подарок!</title>
    <style>
        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            background-color: #f0f0f0;
            overflow: hidden;
        }

        /* Общий стиль для всех экранов */
        .scene {
            position: absolute;
            width: 100vw;
            height: 100vh;
            background-size: cover;
            background-position: center;
            cursor: pointer;
            display: none; /* Скрываем все сцены по умолчанию */
            transition: opacity 0.5s ease-in-out;
        }

        /* Показываем только активную сцену */
        .active {
            display: block;
        }

        /* Сцена 1: Закрытый конверт на фоне шаров */
        #scene1 { background-image: url('https://gcdnb.pbrd.co/images/jA1FeTW5ogKE.png?o=1'); }
        #scene1::after {
            content: "";
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            width: 300px; height: 200px;
            background: url('https://gcdnb.pbrd.co/images/ClSXZWA3SoD2.png?o=1') no-repeat center/contain;
        }

        /* Сцена 2: Открытое письмо */
        #scene2 { background-image: url('https://gcdnb.pbrd.co/images/jA1FeTW5ogKE.png?o=1'); }
        #scene2 .letter {
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            width: 80%; height: 80%;
            background: url('https://gcdnb.pbrd.co/images/Nouv0xVOiJED.png?o=1') no-repeat center/contain;
        }

        /* Сцена 3: Заставка игры */
        #scene3 { background-image: url('https://gcdnb.pbrd.co/images/MuK71pVhfAW4.png?o=1'); background-size: contain; background-repeat: no-repeat; background-color: white;}

        /* Сцена 4: Сама игра (выбор коробок) */
        #scene4 { background-image: url('https://gcdnb.pbrd.co/images/I04Dp5EyxmmF.png?o=1'); background-size: contain; background-repeat: no-repeat; background-color: white;}

        /* Сцена 5: Финал с микрофоном */
        #scene5 { background-image: url('https://gcdnb.pbrd.co/images/iXUtKGAXPPbq.png?o=1'); background-size: contain; background-repeat: no-repeat; background-color: white;}

        /* Подсказка внизу */
        .hint {
            position: absolute;
            bottom: 20px;
            width: 100%;
            text-align: center;
            color: #888;
            font-family: sans-serif;
            pointer-events: none;
        }
    </style>
</head>
<body>

    <div id="scene1" class="scene active" onclick="nextScene(2)">
        <div class="hint">Нажми на конверт, чтобы открыть</div>
    </div>

    <div id="scene2" class="scene" onclick="nextScene(3)">
        <div class="letter"></div>
        <div class="hint">Прочитай и жми дальше</div>
    </div>

    <div id="scene3" class="scene" onclick="nextScene(4)">
        <div class="hint">Нажми "Начать игру" (или просто по экрану)</div>
    </div>

    <div id="scene4" class="scene" onclick="nextScene(5)">
        <div class="hint">Выбери любую коробку!</div>
    </div>

    <div id="scene5" class="scene">
        <div class="hint">Ура! Твой подарок — микрофон! 🎤</div>
    </div>

    <script>
        function nextScene(sceneNumber) {
            // Скрываем все сцены
            const scenes = document.querySelectorAll('.scene');
            scenes.forEach(s => s.classList.remove('active'));

            // Показываем нужную
            const next = document.getElementById('scene' + sceneNumber);
            if (next) {
                next.classList.add('active');
            }
        }
    </script>
</body>
</html>
