<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>С Днём Рождения!</title>

<link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;600&family=Montserrat:wght@300;400;500;600&family=Great+Vibes&display=swap" rel="stylesheet">

<style>
:root {
  --magenta: #f035e0;
  --magenta-hover: #d020c0;
  --text-dark: #333;
  --text-light: #666;
}

* { box-sizing: border-box; margin: 0; padding: 0; }
html, body { height: 100%; overflow: hidden; font-family: 'Montserrat', sans-serif; }

.screen {
  position: fixed; inset: 0;
  display: flex; align-items: center; justify-content: center;
  opacity: 0; pointer-events: none;
  transition: 0.6s;
}
.screen.active { opacity: 1; pointer-events: all; }

/* Фоны */
.bg-light {
  position: absolute; inset: 0; z-index: -2;
  background: linear-gradient(135deg, #fdf5f4, #f7e6e5);
}

.bg-room {
  position: absolute; inset: 0; z-index: -2;
  background: url('https://images.unsplash.com/photo-1549465220-1a8b9238cd48?q=80&w=2070') center/cover no-repeat;
}

/* Нижние подарки */
.bottom-gifts-left {
  position: absolute; bottom: 0; left: 0; width: 250px;
}
.bottom-gifts-right {
  position: absolute; bottom: 0; right: 0; width: 250px;
}

/* Landing */
.landing-layout {
  display: flex; gap: 50px; align-items: center;
}

.hb-happy { font-size: 40px; }
.hb-birthday { font-size: 90px; font-family: 'Great Vibes'; }
.hb-sub { font-size: 16px; }

.envelope-wrapper {
  cursor: pointer;
  animation: float 3s infinite;
}
@keyframes float {
  50% { transform: translateY(-15px); }
}

/* Модалка */
.modal {
  background: #fff;
  padding: 40px;
  border-radius: 20px;
  text-align: center;
}

.btn {
  background: var(--magenta);
  color: #fff;
  border: none;
  padding: 15px 30px;
  border-radius: 50px;
  cursor: pointer;
}

/* Игра */
.hearts-container { margin-bottom: 20px; }
.heart { width: 25px; fill: red; }
.heart.lost { fill: #ccc; }

.boxes-container { display: flex; gap: 20px; }
.box-btn { background: none; border: none; cursor: pointer; }

/* Победа */
.win-modal {
  display: flex;
  background: #fff;
  border-radius: 20px;
  overflow: hidden;
}

.win-note-side {
  padding: 20px;
  background: #fffaf0;
}

.win-prize-side {
  padding: 20px;
  text-align: center;
}

#confetti {
  position: fixed; inset: 0;
  pointer-events: none;
}
</style>
</head>

<body>

<canvas id="confetti"></canvas>

<!-- Экран 1 -->
<div class="screen active" id="s1">
  <div class="bg-light"></div>

  <div class="landing-layout">
    <div>
      <div class="hb-happy">Happy</div>
      <div class="hb-birthday">Birthday</div>
      <div class="hb-sub">Best Wishes!</div>
    </div>

    <div class="envelope-wrapper" onclick="goTo('s2')">
      📩
    </div>
  </div>
</div>

<!-- Экран 2 -->
<div class="screen" id="s2">
  <div class="bg-room"></div>

  <img src="https://cdn-icons-png.flaticon.com/512/3468/3468379.png" class="bottom-gifts-left">
  <img src="https://cdn-icons-png.flaticon.com/512/3468/3468379.png" class="bottom-gifts-right">

  <div class="modal">
    <h2>Мини-игра</h2>
    <p>Угадай коробку 🎁</p>
    <button class="btn" onclick="startGame()">Начать</button>
  </div>
</div>

<!-- Экран 3 -->
<div class="screen" id="s3">
  <div class="bg-room"></div>

  <div class="modal">
    <div class="hearts-container">
      ❤️ ❤️ ❤️
    </div>

    <div class="boxes-container">
      <button class="box-btn" onclick="pickBox(this)">🎁</button>
      <button class="box-btn" onclick="pickBox(this)">🎁</button>
      <button class="box-btn" onclick="pickBox(this)">🎁</button>
    </div>
  </div>
</div>

<!-- Экран 4 -->
<div class="screen" id="s4">
  <div class="bg-room"></div>

  <div class="win-modal">
    <div class="win-note-side">
      🎉 Поздравляю! Ты выиграла!
    </div>

    <div class="win-prize-side">
      <h3>Твой подарок 🎁</h3>
      ❤️
    </div>
  </div>
</div>

<script>
function goTo(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

let lives = 3;

function startGame() {
  lives = 3;
  goTo('s3');
}

function pickBox(btn) {
  if (lives > 1) {
    lives--;
    btn.style.opacity = '0.3';
    btn.disabled = true;
  } else {
    goTo('s4');
    fireConfetti();
  }
}

/* Конфетти */
function fireConfetti() {
  const canvas = document.getElementById('confetti');
  const ctx = canvas.getContext('2d');

  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;

  let pieces = [];

  for (let i = 0; i < 120; i++) {
    pieces.push({
      x: canvas.width / 2,
      y: canvas.height / 2,
      vx: (Math.random() - 0.5) * 10,
      vy: Math.random() * -10,
      size: Math.random() * 6
    });
  }

  function draw() {
    ctx.clearRect(0,0,canvas.width,canvas.height);

    pieces.forEach(p => {
      p.x += p.vx;
      p.y += p.vy;
      p.vy += 0.3;

      ctx.fillRect(p.x, p.y, p.size, p.size);
    });

    requestAnimationFrame(draw);
  }

  draw();
}
</script>

</body>
</html>
