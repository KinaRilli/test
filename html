<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>С Днем Рождения!</title>
    <style>
        /* Основные настройки страницы */
        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            overflow: hidden; /* Чтобы не было полос прокрутки */
            font-family: Arial, sans-serif;
        }

        /* ФОН КОМНАТЫ */
        .background {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: url('https://gcdnb.pbrd.co/images/jA1FeTW5ogKE.png?o=1');
            background-size: cover;
            background-position: center;
            z-index: -1;
        }

        /* ОБЩИЙ КОНТЕЙНЕР ДЛЯ ЭЛЕМЕНТОВ */
        .scene {
            position: relative;
            width: 100vw;
            height: 100vh;
        }

        /* ШАРИКИ (Декор) */
        .decor {
            position: absolute;
            transition: transform 0.3s ease;
        }
        
        .balloons-left {
            width: 200px;
            top: 10%;
            left: 5%;
            /* Ссылка на первые шарики */
            content: url('https://gcdnb.pbrd.co/images/Nouv0xVOiJED.png?o=1');
        }

        .balloons-right {
            width: 180px;
            top: 5%;
            right: 10%;
            /* Ссылка на вторые шарики */
            content: url('https://gcdnb.pbrd.co/images/I04Dp5EyxmmF.png?o=1');
        }

        .decor-extra {
            width: 150px;
            bottom: 10%;
            left: 10%;
            /* Ссылка на третий декор */
            content: url('https://gcdnb.pbrd.co/images/iXUtKGAXPPbq.png?o=1');
        }

        /* МИКРОФОН */
        .microphone {
            position: absolute;
            width: 120px;
            bottom: 15%;
            right: 15%;
            cursor: pointer;
            filter: drop-shadow(0 0 10px rgba(255,255,255,0.5));
            /* Ссылка на микрофон */
            content: url('https://gcdnb.pbrd.co/images/MuK71pVhfAW4.png?o=1');
        }
        
        .microphone:hover {
            transform: scale(1.1);
        }

        /* КОНВЕРТ (Центральный элемент) */
        .envelope {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 250px;
            cursor: pointer;
            transition: all 0.5s ease;
            /* Ссылка на конверт */
            content: url('https://gcdnb.pbrd.co/images/ClSXZWA3SoD2.png?o=1');
        }

        .envelope:hover {
            transform: translate(-50%, -60%) rotate(-5deg);
            filter: brightness(1.1);
        }

        /* ТЕКСТ ПОДПИСИ */
        .title {
            position: absolute;
            top: 10%;
            width: 100%;
            text-align: center;
            color: white;
            font-size: 2.5em;
            text-shadow: 2px 2px 10px rgba(0,0,0,0.5);
            pointer-events: none;
        }

    </style>
</head>
<body>

    <div class="background"></div>

    <div class="scene">
        <h1 class="title">С Днём Рождения! 🎂</h1>

        <div class="decor balloons-left"></div>
        <div class="decor balloons-right"></div>
        <div class="decor decor-extra"></div>

        <div class="microphone"></div>

        <div class="envelope" onclick="alert('Тут будет твое поздравление!')"></div>
    </div>

</body>
</html>
